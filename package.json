{
  "name": "electron-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:linux": "turbo run build:linux",
    "build:mac": "turbo run build:mac",
    "build:unpack": "turbo run build:unpack",
    "build:win": "turbo run build:win",
    "check": "ultracite check",
    "dev": "turbo run dev",
    "fix": "ultracite fix",
    "lint": "ultracite check",
    "prepare": "husky",
    "release": "node scripts/release.mjs",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "turbo": "latest",
    "ultracite": "7.6.2"
  },
  "packageManager": "bun@1.3.11"
}
