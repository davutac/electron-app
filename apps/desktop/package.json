{
  "name": "@repo/desktop",
  "version": "0.0.2",
  "private": true,
  "description": "An Electron application with React and TypeScript",
  "homepage": "https://davutcaliskan.de",
  "author": "Davut Caliskan",
  "repository": {
    "type": "git",
    "url": "https://github.com/davutac/electron-app.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "bun run typecheck && electron-vite build",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:unpack": "electron-builder --dir",
    "build:win": "electron-builder --win",
    "dev": "bun run ensure:electron && electron-vite dev",
    "ensure:electron": "node node_modules/electron/install.js",
    "postinstall": "bun run ensure:electron && electron-builder install-app-deps",
    "start": "bun run ensure:electron && electron-vite preview",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@repo/database": "workspace:*",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-router": "^1.169.2",
    "better-result": "^2.9.2",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.5.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "6.0.0-beta.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
