{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/constants.ts",
    "src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@/renderer/*": ["./src/renderer/src/*"],
      "@/constants": ["./src/constants.ts"]
    },
    "strictNullChecks": true
  }
}
