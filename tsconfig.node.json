{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/constants.ts"],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@/constants": ["./src/constants.ts"]
    },
    "types": ["electron-vite/node"],
    "strictNullChecks": true
  }
}
