{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**", "dist/**"]
    },
    "build:linux": {
      "dependsOn": ["build"],
      "outputs": ["dist/**"]
    },
    "build:mac": {
      "dependsOn": ["build"],
      "outputs": ["dist/**"]
    },
    "build:unpack": {
      "dependsOn": ["build"],
      "outputs": ["dist/**"]
    },
    "build:win": {
      "dependsOn": ["build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@repo/backend#deploy": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {}
  }
}
